{% extends 'base.html.twig' %}

{% block title %}Nouvelle note{% endblock %}

{% block body %}
    <main style="max-width: 40rem; margin: 2rem auto; padding: 0 1rem; font-family: system-ui, sans-serif;">
        <p><a href="{{ path('app_note_index') }}">← Liste des notes</a></p>
        <h1>Nouvelle note</h1>
        {{ form_start(form) }}
            {{ form_row(form.title) }}
            {{ form_row(form.content) }}
            <button type="submit" style="margin-top: 1rem;">Enregistrer</button>
        {{ form_end(form) }}
    </main>
{% endblock %}
